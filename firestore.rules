rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function ownsUserDoc(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function ownsResource() {
      return signedIn() && request.resource.data.userId == request.auth.uid;
    }

    function ownsExisting() {
      return signedIn() && resource.data.userId == request.auth.uid;
    }

    match /users/{userId} {
      allow read, create, update: if ownsUserDoc(userId);
      allow delete: if false;
    }

    match /transactions/{id} {
      allow read, update, delete: if ownsExisting();
      allow create: if ownsResource();
    }

    match /budgets/{id} {
      allow read, update, delete: if ownsExisting();
      allow create: if ownsResource();
    }

    match /recurringExpenses/{id} {
      allow read, update, delete: if ownsExisting();
      allow create: if ownsResource();
    }

    match /dailyClosings/{id} {
      allow read, update, delete: if ownsExisting();
      allow create: if ownsResource();
    }

    match /auditLogs/{id} {
      allow read: if ownsExisting();
      allow create: if ownsResource();
      allow update, delete: if false;
    }
  }
}
